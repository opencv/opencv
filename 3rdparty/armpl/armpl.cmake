set(ARMPL_VERSION "26.01")
if(WIN32)
  if(CMAKE_SIZEOF_VOID_P EQUAL 8)
    if(CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64|aarch64|arm64")
      set(ARMPL_FILENAME "arm-performance-libraries_26.01_Windows.msi")
      set(ARMPL_URL "https://developer.arm.com/-/cdn-downloads/permalink/Arm-Performance-Libraries/Version_26.01/arm-performance-libraries_26.01_Windows.msi")
      set(ARMPL_HASH "da2d9b6a5d1ef5467f3a07a3c5efdd4a")
      set(ARMPL_INSTALL_SUBDIR "armpl_26.01_windows_arm64")
    endif()
  endif()
endif()

if(DEFINED ARMPL_FILENAME)
  set(ARMPL_BINARIES_ARCHIVE "${ARMPL_FILENAME}")
  set(ARMPL_DOWNLOAD_URL "${ARMPL_URL}")
  set(ARMPL_DOWNLOAD_HASH "${ARMPL_HASH}")
  set(ARMPL_SUBDIR "${ARMPL_INSTALL_SUBDIR}")
else()
  message(STATUS "ARM Performance Libraries: No download configuration for this platform")
endif()
